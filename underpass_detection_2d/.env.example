# Database connection settings
UNDERPASS_DETECTION_2D_DB_HOST=localhost
UNDERPASS_DETECTION_2D_DB_PORT=5432
UNDERPASS_DETECTION_2D_DB_NAME=your_database
UNDERPASS_DETECTION_2D_DB_USER=your_user
UNDERPASS_DETECTION_2D_DB_PASSWORD=your_password

# Processing settings
UNDERPASS_DETECTION_2D_MAX_WORKERS=6
UNDERPASS_DETECTION_2D_CHUNK_SIZE=1000
UNDERPASS_DETECTION_2D_SNAP_TOLERANCE=0.01
UNDERPASS_DETECTION_2D_BUFFER_DISTANCE=0.2

# Output tables (format: schema.tablename)
UNDERPASS_DETECTION_2D_BAG_BGT_JOIN_TABLE=underpasses.bag_bgt_join
UNDERPASS_DETECTION_2D_BAG_MINUS_BGT_TABLE=underpasses.bag_minus_bgt
UNDERPASS_DETECTION_2D_SNAPPED_DIFFERENCES_TABLE=underpasses.snapped_differences
UNDERPASS_DETECTION_2D_GEOMETRIES_TABLE=underpasses.geometries
